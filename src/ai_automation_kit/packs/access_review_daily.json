{
  "schema_version": 1,
  "id": "access-review-daily",
  "display_name": {
    "ja": "アクセス棚卸日次整理",
    "en": "Access Review Daily"
  },
  "category": "compliance",
  "period_type": "day",
  "risk_tier": "high",
  "business_outcome": "Prepare a sourced daily access review exception draft for human review",
  "inputs": [
    {
      "id": "access_review_export",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "role_or_entitlement_matrix",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".pdf"
      ]
    },
    {
      "id": "exception_or_joiner_mover_leaver_log",
      "required": false,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".txt"
      ]
    }
  ],
  "questions": [
    {
      "id": "privileged_access_scope_rule",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "review_escalation_and_approval_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "same_day_access_change_hold_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "access-review-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "access_review_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "security_or_it_approver"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "access_revocation",
    "permission_grant",
    "access_certification"
  ],
  "success_metrics": [
    "privileged_exception_capture_rate",
    "missing_fact_count",
    "review_minutes"
  ]
}
