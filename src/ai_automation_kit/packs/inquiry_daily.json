{
  "schema_version": 1,
  "id": "inquiry-daily",
  "display_name": {
    "ja": "問い合わせ日次整理",
    "en": "Inquiry Daily"
  },
  "category": "operations",
  "period_type": "day",
  "risk_tier": "low",
  "business_outcome": "Prepare a sourced daily inquiry triage draft for human review",
  "inputs": [
    {
      "id": "inquiry_queue_export",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".txt"
      ]
    },
    {
      "id": "product_or_policy_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "priority_definition",
      "type": "short_text",
      "required": true,
      "max_length": 200
    },
    {
      "id": "same_day_escalation_rule",
      "type": "long_text",
      "required": false,
      "max_length": 600
    },
    {
      "id": "response_window",
      "type": "single_choice",
      "required": true,
      "options": [
        "same_day",
        "next_business_day",
        "within_two_business_days"
      ]
    }
  ],
  "prompt_template_id": "inquiry-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "inquiry_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "inquiry_owner"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "customer_reply"
  ],
  "success_metrics": [
    "triage_minutes",
    "missing_fact_count",
    "priority_alignment_rate"
  ]
}
