{
  "schema_version": 1,
  "id": "grant-packet-daily",
  "display_name": {
    "ja": "助成金申請資料日次整理",
    "en": "Grant Packet Daily"
  },
  "category": "compliance",
  "period_type": "day",
  "risk_tier": "high",
  "business_outcome": "Prepare a sourced daily grant packet draft for human review",
  "inputs": [
    {
      "id": "grant_notice_or_program_guidelines",
      "required": true,
      "accepted_extensions": [
        ".pdf",
        ".docx",
        ".md",
        ".txt"
      ]
    },
    {
      "id": "eligibility_and_budget_workbook",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "supporting_attachment_evidence",
      "required": false,
      "accepted_extensions": [
        ".pdf",
        ".docx",
        ".md",
        ".txt",
        ".json"
      ]
    }
  ],
  "questions": [
    {
      "id": "eligibility_boundary_rule",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "narrative_and_attachment_expectation_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "same_day_submission_hold_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "grant-packet-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "grant_packet_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "grant_or_finance_approver"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "grant_submission",
    "eligibility_certification",
    "award_promise"
  ],
  "success_metrics": [
    "packet_completeness",
    "missing_fact_count",
    "review_minutes"
  ]
}
