{
  "schema_version": 1,
  "id": "finance-daily",
  "display_name": {
    "ja": "財務日次確認",
    "en": "Finance Daily"
  },
  "category": "finance",
  "period_type": "day",
  "risk_tier": "medium",
  "business_outcome": "Prepare a sourced daily finance exception draft for human review",
  "inputs": [
    {
      "id": "cash_and_balance_exports",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".pdf"
      ]
    },
    {
      "id": "ap_ar_supporting_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".docx",
        ".pdf"
      ]
    }
  ],
  "questions": [
    {
      "id": "cash_watch_items",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "materiality_threshold",
      "type": "short_text",
      "required": true,
      "max_length": 120
    },
    {
      "id": "same_day_escalation_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "finance-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "finance_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "finance_manager"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "ledger_post",
    "bank_transfer"
  ],
  "success_metrics": [
    "review_minutes",
    "exception_capture_rate",
    "missing_fact_count"
  ]
}
