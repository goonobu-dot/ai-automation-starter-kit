{
  "schema_version": 1,
  "id": "spreadsheet-reconciliation-daily",
  "display_name": {
    "ja": "表計算照合日次確認",
    "en": "Spreadsheet Reconciliation Daily"
  },
  "category": "finance",
  "period_type": "day",
  "risk_tier": "medium",
  "business_outcome": "Prepare a sourced daily spreadsheet reconciliation exception draft for human review",
  "inputs": [
    {
      "id": "ledger_export",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".pdf"
      ]
    },
    {
      "id": "bank_or_subledger_statement",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".pdf"
      ]
    },
    {
      "id": "reconciliation_policy_or_prior_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "reconciliation_cutoff_rule",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "unreconciled_item_escalation_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "same_day_journal_hold_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "spreadsheet-reconciliation-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "spreadsheet_reconciliation_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "finance_approver"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "journal_entry_posting",
    "reconciliation_signoff",
    "balance_adjustment"
  ],
  "success_metrics": [
    "reconciliation_exception_capture_rate",
    "missing_fact_count",
    "review_minutes"
  ]
}
