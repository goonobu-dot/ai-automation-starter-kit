{
  "schema_version": 1,
  "id": "policy-change-impact-daily",
  "display_name": {
    "ja": "規程変更影響日次整理",
    "en": "Policy Change Impact Daily"
  },
  "category": "compliance",
  "period_type": "day",
  "risk_tier": "high",
  "business_outcome": "Prepare a sourced daily policy change impact draft for human review",
  "inputs": [
    {
      "id": "policy_change_notice",
      "required": true,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx",
        ".json"
      ]
    },
    {
      "id": "control_or_process_inventory",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "incident_or_exception_log",
      "required": false,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".txt"
      ]
    }
  ],
  "questions": [
    {
      "id": "material_impact_definition",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "mandatory_approval_or_training_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "immediate_control_freeze_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "policy-change-impact-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "policy_change_impact_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "compliance_owner"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "policy_publication",
    "control_change",
    "training_assignment",
    "attestation_request"
  ],
  "success_metrics": [
    "impact_risk_capture_rate",
    "missing_fact_count",
    "review_minutes"
  ]
}
