{
  "schema_version": 1,
  "id": "compliance-deadline-daily",
  "display_name": {
    "ja": "コンプライアンス期限日次整理",
    "en": "Compliance Deadline Daily"
  },
  "category": "compliance",
  "period_type": "day",
  "risk_tier": "high",
  "business_outcome": "Prepare a sourced daily compliance deadline risk draft for human review",
  "inputs": [
    {
      "id": "compliance_obligation_register",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "evidence_or_filing_status_log",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".txt"
      ]
    },
    {
      "id": "policy_or_regulatory_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "material_breach_definition",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "escalation_and_evidence_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "regulator_notification_hold_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "compliance-deadline-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "compliance_deadline_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "compliance_owner"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "regulatory_filing",
    "policy_attestation",
    "deadline_extension_request"
  ],
  "success_metrics": [
    "deadline_risk_capture_rate",
    "missing_fact_count",
    "review_minutes"
  ]
}
