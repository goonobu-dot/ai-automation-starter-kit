{
  "schema_version": 1,
  "id": "quality-incident-capa-daily",
  "display_name": {
    "ja": "品質事故・是正予防措置日次整理",
    "en": "Quality Incident CAPA Daily"
  },
  "category": "operations",
  "period_type": "day",
  "risk_tier": "high",
  "business_outcome": "Prepare a sourced daily quality incident and CAPA risk draft for human review",
  "inputs": [
    {
      "id": "quality_incident_log",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md",
        ".txt"
      ]
    },
    {
      "id": "capa_tracker",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "supporting_evidence_or_audit_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "critical_quality_risk_definition",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "containment_and_capa_escalation_rule",
      "type": "long_text",
      "required": true,
      "max_length": 600
    },
    {
      "id": "shipment_or_release_hold_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "quality-incident-capa-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "quality_incident_capa_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "quality_owner"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "capa_closure",
    "product_disposition_change",
    "release_authorization",
    "supplier_notification"
  ],
  "success_metrics": [
    "incident_risk_capture_rate",
    "missing_fact_count",
    "review_minutes"
  ]
}
