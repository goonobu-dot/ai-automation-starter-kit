{
  "schema_version": 1,
  "id": "handover-deadline-daily",
  "display_name": {
    "ja": "引き継ぎ・期限日次整理",
    "en": "Handover and Deadline Daily"
  },
  "category": "operations",
  "period_type": "day",
  "risk_tier": "medium",
  "business_outcome": "Prepare a sourced daily handover and deadline risk draft for human review",
  "inputs": [
    {
      "id": "work_item_tracker_export",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "handover_notes_or_shift_log",
      "required": true,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".docx",
        ".pdf"
      ]
    },
    {
      "id": "dependency_or_capacity_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "deadline_breach_definition",
      "type": "short_text",
      "required": true,
      "max_length": 160
    },
    {
      "id": "handover_owner_rule",
      "type": "long_text",
      "required": true,
      "max_length": 500
    },
    {
      "id": "same_day_escalation_required",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "handover-deadline-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "handover_deadline_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "operations_lead"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "deadline_change",
    "task_reassignment"
  ],
  "success_metrics": [
    "deadline_risk_capture_rate",
    "handover_gap_count",
    "review_minutes"
  ]
}
