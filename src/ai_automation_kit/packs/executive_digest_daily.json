{
  "schema_version": 1,
  "id": "executive-digest-daily",
  "display_name": {
    "ja": "経営ダイジェスト日次整理",
    "en": "Executive Digest Daily"
  },
  "category": "executive",
  "period_type": "day",
  "risk_tier": "medium",
  "business_outcome": "Prepare a sourced daily executive digest draft with open questions and risks",
  "inputs": [
    {
      "id": "daily_metric_snapshot",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "risk_and_decision_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".pdf",
        ".docx"
      ]
    }
  ],
  "questions": [
    {
      "id": "top_decision_focus",
      "type": "short_text",
      "required": true,
      "max_length": 200
    },
    {
      "id": "material_change_definition",
      "type": "long_text",
      "required": false,
      "max_length": 600
    },
    {
      "id": "board_level_attention_needed",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "executive-digest-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "executive_digest_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "executive_owner"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "board_distribution"
  ],
  "success_metrics": [
    "review_minutes",
    "missing_fact_count",
    "risk_capture_rate"
  ]
}
