{
  "schema_version": 1,
  "id": "project-daily",
  "display_name": {
    "ja": "案件進行日次整理",
    "en": "Project Daily"
  },
  "category": "projects",
  "period_type": "day",
  "risk_tier": "low",
  "business_outcome": "Prepare a sourced daily project status draft with blockers and next steps",
  "inputs": [
    {
      "id": "project_tracker_export",
      "required": true,
      "accepted_extensions": [
        ".csv",
        ".xlsx",
        ".json",
        ".md"
      ]
    },
    {
      "id": "blocker_notes",
      "required": false,
      "accepted_extensions": [
        ".md",
        ".txt",
        ".docx",
        ".pdf"
      ]
    }
  ],
  "questions": [
    {
      "id": "today_milestone_focus",
      "type": "short_text",
      "required": true,
      "max_length": 200
    },
    {
      "id": "delivery_risk_definition",
      "type": "long_text",
      "required": false,
      "max_length": 600
    },
    {
      "id": "customer_visible_changes",
      "type": "confirmation",
      "required": false
    }
  ],
  "prompt_template_id": "project-daily-v1",
  "allowed_prompt_variables": [
    "period_id",
    "source_manifest",
    "answers"
  ],
  "outputs": [
    {
      "id": "draft",
      "relative_path": "project_daily.md",
      "max_bytes": 1048576
    }
  ],
  "approval": {
    "required": true,
    "role": "project_manager"
  },
  "prohibited_actions": [
    "external_send",
    "publish",
    "payment",
    "production_write",
    "self_approve",
    "task_status_change"
  ],
  "success_metrics": [
    "drafting_minutes",
    "blocker_capture_rate",
    "missing_fact_count"
  ]
}
